# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/slipgate

# NextAuth
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# ─── TrueMoney Webhook (Push channel) ───────────────────────────────────
# จากแอป TrueMoney → ทรูมันนี่ → Webhook & API Services
# Body shape:  { "message": "<JWT HS256>" }
# Header:      Authorization: <auth_key>
# Amount in payload เป็น "satang" integer (10000 = 100.00 บาท)
#
# TMN ออก key คนละชุดต่อ webhook (แจ้งรับเงิน vs แจ้งหักค่าธรรมเนียม/ถอน).
# ใส่ทั้งสองช่องเพื่อรับครบทุก event type. JWT secret = ค่าเดียวกับ auth key
# ใน UI ใหม่ของ TMN — ถ้าไม่ใส่ TMN_WEBHOOK_JWT_SECRET_* จะ fallback ใช้ auth key.
#
# Inbound = เงินเข้า (P2P, MONEY_LINK, DIRECT_TOPUP, PROMPTPAY_IN)
TMN_WEBHOOK_AUTH_KEY_INBOUND=
TMN_WEBHOOK_JWT_SECRET_INBOUND=

# Outbound = เงินออก/ค่าธรรมเนียม (BANK_WITHDRAW, SEND_P2P, FEE_PAYMENT, ฯลฯ)
TMN_WEBHOOK_AUTH_KEY_OUTBOUND=
TMN_WEBHOOK_JWT_SECRET_OUTBOUND=

# Legacy single-key fallback (deprecated — ใช้ INBOUND/OUTBOUND แทน)
TMN_WEBHOOK_AUTH_KEY=
TMN_WEBHOOK_JWT_SECRET=

# Slip OCR (Anthropic API direct — preferred)
# Get key at https://console.anthropic.com — usage charged per request
ANTHROPIC_API_KEY=
SLIP_OCR_MODEL=claude-haiku-4-5

# Legacy: Vercel AI Gateway (fallback if ANTHROPIC_API_KEY is empty)
AI_GATEWAY_API_KEY=

# Optional: EasySlip 3rd-party API (สำหรับ slip verify ที่แม่นยำขึ้น)
EASYSLIP_API_KEY=

# ─── TrueMoney Service APIs (apis.truemoneyservices.com) ────────────────
# แต่ละเมนูในแอปทรูมันนี่ออก Bearer token แยกกัน — ใส่เฉพาะอันที่จะใช้
# ⚠️ ห้าม commit ค่าจริงลง git — ใช้ .env.local (gitignored)
# ⚠️ ถ้า token รั่ว → กด "สร้างใหม่" ในแอปทันที

# ตรวจสลิป P2P (validate/v1/p2p) — POST verify ด้วย 5 ฟิลด์
TMN_P2P_VALIDATE_TOKEN=

# รายการรับเงินล่าสุดของฉัน (account/v1/my-last-receive) — สำหรับ polling backup
TMN_LAST_RECEIVE_TOKEN=

# ตรวจยอดเงิน (account/v1/balance)
TMN_BALANCE_TOKEN=

# สร้างลิงก์รับเงิน (utils/v1/transfer-link-generator) — คืน tmn.app.link URL
TMN_TRANSFER_LINK_TOKEN=

# ดูข้อมูลจาก QR บนสลิป (utils/v1/trans-qr-info) — masked sender/receiver
TMN_QR_INFO_TOKEN=

# Polling interval สำหรับ background sync (วินาที, 0 = ปิด)
# ⚠️ TrueMoney rate limit: 30 req / 30 sec → ค่าต่ำสุดที่แนะนำ 2 วินาที
TMN_POLL_INTERVAL_SEC=0

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
